# pauldal-marketing — public env vars
#
# All client-exposed env vars must be prefixed with NEXT_PUBLIC_ so Next.js
# inlines them at build time. Server-only secrets do not belong here.

# FRAME API base — the form POSTs leads here. REQUIRED in production
# (book-form.tsx throws at build time if NODE_ENV=production and this is
# unset). The www. prefix is load-bearing: the apex studiofronthq.com
# 307s at the Vercel platform level and redirects kill CORS preflights —
# incident 2026-06-12. Always use https://www.studiofronthq.com directly.
NEXT_PUBLIC_FRAME_API_URL=https://www.studiofronthq.com

# Meta Pixel ID (client-side)
# Add to Vercel env (production + preview) after creating Pixel in Meta Events Manager.
# Defensive: if empty, Pixel does NOT initialize, no errors thrown.
NEXT_PUBLIC_META_PIXEL_ID=
